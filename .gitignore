# ---------------------------------------------------------------------------
# Restricted SLAM-RF data
#
# Ignore every raw file in these two directories, except the two explicitly
# authorized reduced structural examples. Their filenames remain identical to
# the original filenames expected by the scripts.
# ---------------------------------------------------------------------------
create_dataset/RadarHD-dataset-1/lidar_pcl/*
!create_dataset/RadarHD-dataset-1/lidar_pcl/112_fwd.csv

create_dataset/RadarHD-dataset-1/radar/*
!create_dataset/RadarHD-dataset-1/radar/112_read.pkl

# Keep optional documentation placed inside the data directories.
!create_dataset/RadarHD-dataset-1/lidar_pcl/README.md
!create_dataset/RadarHD-dataset-1/radar/README.md

# Intentionally tracked in the private repository:
# - archive/
# - docs/
# - images/
# - cluster/

# digest due to bash files used on cluster
cluster/rcp_config.sh
cluster/delete_jobs_all